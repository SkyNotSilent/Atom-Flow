# APP_URL: Canonical public HTTPS URL. Set this in Railway Variables.
# Railway may also provide RAILWAY_PUBLIC_DOMAIN, but an explicit APP_URL is preferred.
APP_URL="https://your-domain.example"

# SESSION_SECRET: Secret key for session cookie signing; use at least 32 random characters in production.
SESSION_SECRET="replace-with-at-least-32-random-characters"

# Production origin and request controls.
ALLOWED_ORIGINS="https://your-domain.example"
VITE_TLDRAW_LICENSE_KEY="your-production-tldraw-license-key"
API_RATE_LIMIT=300
AUTH_LOGIN_RATE_LIMIT=10
AUTH_CODE_IP_RATE_LIMIT=5
AUTH_CODE_EMAIL_RATE_LIMIT=3
AUTH_VERIFY_RATE_LIMIT=10
PAID_OPERATION_RATE_LIMIT=20
PAID_OPERATION_CONCURRENCY=2
PAID_OPERATION_GLOBAL_CONCURRENCY=8
PAID_OPERATION_LEASE_MS=180000
AI_REQUEST_TIMEOUT_MS=120000
REMOTE_FETCH_RATE_LIMIT=30
REMOTE_RSS_MAX_MB=5
REMOTE_RSS_MAX_ITEMS=500
UPLOAD_RATE_LIMIT=20
CANVAS_UPLOAD_MAX_MB=10
CANVAS_USER_STORAGE_MAX_MB=100
CANVAS_UPLOAD_GLOBAL_CONCURRENCY=4
CANVAS_MAX_NODES_PER_PROJECT=500
CANVAS_MAX_MESSAGES_PER_AGENT=200
CANVAS_MAX_PROJECTS_PER_USER=50
CANVAS_MAX_CONTEXT_ITEMS=30
CANVAS_MAX_CONTEXT_CHARS=60000
CANVAS_MAX_CONTEXT_IMAGE_MB=12
AVATAR_UPLOAD_MAX_MB=5
IMAGE_PROXY_MAX_MB=8
IMAGE_PROXY_TIMEOUT_MS=8000
JSON_BODY_LIMIT_KB=256
ASR_MAX_FRAME_KB=256
ASR_MAX_PENDING_MB=2
ASR_MAX_SESSION_SECONDS=600
ASR_MAX_CONNECTIONS_PER_USER=2
ASR_MAX_GLOBAL_CONNECTIONS=20
ASR_MAX_SESSION_AUDIO_MB=25
ASR_MAX_BYTES_PER_SECOND=1048576
ASR_MAX_UPSTREAM_BUFFER_MB=1
DB_POOL_MAX=10
DB_CONNECTION_TIMEOUT_MS=5000
DB_IDLE_TIMEOUT_MS=30000
DB_STATEMENT_TIMEOUT_MS=30000

# Local development port. Keep this stable so browser URLs, callbacks, and agents do not drift.
PORT=1000

# RESEND_API_KEY: Required for sending verification code emails.
# Get your API key at https://resend.com
RESEND_API_KEY="your-resend-api-key"

# AI Card Extraction (OpenAI-compatible MiMo Token Plan)
AI_API_KEY="your-mimo-token-plan-api-key"
AI_BASE_URL="https://token-plan-sgp.xiaomimimo.com/v1"
AI_MODEL="mimo-v2.5-pro"

# Optional OpenAI official Writing Agent runtime override.
# If omitted, the writing Agent uses AI_API_KEY/AI_BASE_URL/AI_MODEL above.
OPENAI_API_KEY=""
OPENAI_MODEL=""

# Local or isolated integration-test account only. Never point these at production credentials.
TEST_EMAIL=""
TEST_PASSWORD=""
